<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<!--
  Manifest for hope-Office Web Add-in.
  Proven-valid shape — mirrors autoOffice's archived
  manifest which the user successfully sideloaded in the
  past. Diff vs. an Office Add-in tutorial's starter:

    - No <Runtimes>            (V1_0 schema doesn't take it;
                                 V1_1 introduced it. Excel
                                 online rejects it in V1_0.)
    - No <FunctionFile>        (would require a separate JS
                                 handler page registered via
                                 Office.initialize; we don't
                                 have one and don't need one.)
    - No <Requirements>/<bt:Sets>
                                (optional; autoOffice doesn't
                                 declare it.)
    - Only ShowTaskpane actions (no ExecuteFunction).

  Schema: VersionOverridesV1_0. CustomTab is V1_1-only,
  so we land the buttons in the host's existing Home tab
  with <OfficeTab id="TabHome">.
-->
<OfficeApp
  xmlns="http://schemas.microsoft.com/office/appforoffice/1.1"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0"
