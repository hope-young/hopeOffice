  <SupportUrl DefaultValue="https://github.com/hope-young/hopeOffice/issues" />

  <AppDomains>
    <AppDomain>https://localhost:3721</AppDomain>
  </AppDomains>

  <Hosts>
    <Host Name="Document" />
    <Host Name="Workbook" />
