  <DefaultLocale>en-US</DefaultLocale>
  <!--
    DisplayName deliberately doesn't match autoOffice's
    "hope-Office" (with a hyphen). When a tenant has both
    add-ins installed, the manifest GUID is the real
    identity, but the *displayed* name in the My Add-ins
    list, the AppSource, and the task-pane title bar all
    match. Differentiating on DisplayName makes it obvious
    to the user which one is which — and when the Office
    ribbon shows the add-in's group, the tab name is
    derived from the manifest's DisplayName, so a
    "hopeOffice" (no hyphen) tab is visually distinct
    from the autoOffice tab.

    The " (2026)" suffix is a deliberate generation tag.
    If we ship a v2, we'll bump the version, regenerate
    the icons, and bump the suffix to " (2026.2)" — the
    same pattern the macOS / iOS ecosystem uses to mark
    "this is the supported build, not a 2023 fork".
  -->
  <DisplayName DefaultValue="hopeOffice (2026)">
    <Override Locale="zh-CN" Value="hopeOffice (2026)" />
  </DisplayName>
  <Description DefaultValue="AI assistant for Word, Excel, and PowerPoint. Local-first, BYO API key. Generative chart formatting + skill registry + MCP tool calling.">
